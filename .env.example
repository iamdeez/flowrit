# =============================================================================
# Database (Neon PostgreSQL)
#
# 발급처: https://neon.tech
# 가입 → New Project 생성 → Dashboard → Connection Details
# → Connection string 탭에서 복사 (pooled connection 권장)
# =============================================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# =============================================================================
# NextAuth v5
#
# AUTH_SECRET:
#   터미널에서 직접 생성: openssl rand -base64 32
#   또는 온라인 생성: https://generate-secret.vercel.app/32
#
# AUTH_URL:
#   로컬: http://localhost:3000
#   배포 후: https://your-domain.vercel.app (또는 커스텀 도메인)
# =============================================================================
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# =============================================================================
# Cloudflare R2 (파일 업로드)
#
# 발급처: https://dash.cloudflare.com
# 순서:
#   1. 가입 후 좌측 메뉴 R2 Object Storage 클릭
#   2. Create bucket → 버킷명 입력 (예: flowrit-uploads)
#   3. 버킷 생성 후 Settings → Public access → Allow Access 활성화
#      → R2_PUBLIC_URL: 활성화 후 표시되는 r2.dev 주소 사용
#   4. 좌측 R2 메뉴 → Overview → Manage R2 API tokens → Create API token
#      → Permissions: Object Read & Write 선택
#      → R2_ACCOUNT_ID: 같은 페이지 우측 하단 "Account ID" 값
#      → R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY: 토큰 생성 직후 화면에서 복사
#         (Secret Access Key는 이 시점에만 확인 가능)
# =============================================================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="flowrit-uploads"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# =============================================================================
# Resend (이메일 발송 — 팀원 초대)
#
# 발급처: https://resend.com
# 가입 → API Keys → Create API Key → 이름 입력 → 생성된 키 복사
#   (키는 생성 시 1회만 표시되므로 즉시 복사)
#
# RESEND_FROM_EMAIL:
#   무료 플랜: onboarding@resend.dev 사용 가능 (도메인 인증 없이 테스트)
#   실제 도메인: Resend → Domains → Add Domain → DNS 레코드 등록 후 사용
# =============================================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# =============================================================================
# App
#
# NEXT_PUBLIC_APP_URL: 고객 공유 링크(/p/[token]), 의뢰 접수 URL(/intake/[slug]) 생성 기준
#   로컬: http://localhost:3000
#   배포 후: Vercel → 프로젝트 → Settings → Domains에서 확인한 URL로 변경
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# Sentry (에러 트래킹)
#
# 발급처: https://sentry.io
# 가입 → 프로젝트 생성 (Next.js 선택) → Settings → Client Keys (DSN)
# DSN은 공개 값이므로 NEXT_PUBLIC_ 접두사 사용
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN="https://xxxxx@oxxxx.ingest.sentry.io/xxxxx"

# =============================================================================
# 웹훅 · Cron 보안
#
# WEBHOOK_SECRET: 외부 플랫폼이 /api/webhooks/intake/[slug] 호출 시 사용하는 Bearer 토큰
#   생성: openssl rand -hex 32
#
# CRON_SECRET: Vercel Cron이 /api/cron/* 엔드포인트 호출 시 사용하는 Bearer 토큰
#   생성: openssl rand -hex 32
# =============================================================================
WEBHOOK_SECRET="your-webhook-secret-here"
CRON_SECRET="your-cron-secret-here"
HEALTHCHECK_TOKEN="your-healthcheck-token-here"

# =============================================================================
# Discord 운영 알림
#
# 장애/결제 실패/Cron 실패 등 운영 이벤트를 받을 Discord Webhook URL
# Discord 채널 → Edit Channel → Integrations → Webhooks → New Webhook
# =============================================================================
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# =============================================================================
# Upstash Redis (API Rate Limiting)
#
# 발급처: https://upstash.com (무료 플랜 가능)
# 가입 → Create Database → REST API 탭 → URL과 Token 복사
#
# 미설정 시 rate limit이 비활성화된 채로 동작합니다 (개발 환경 등).
# 운영 환경에서는 반드시 설정 권장.
# =============================================================================
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# =============================================================================
# 나이스페이먼츠 (결제 · 구독)
#
# 발급처: https://developers.nicepay.co.kr
# 가입 → 상점 관리 → API 키 발급에서 클라이언트 ID / 시크릿 키 확인
#
# NEXT_PUBLIC_NICEPAY_CLIENT_ID: 브라우저 AUTHNICE.requestPay 초기화에 사용 (공개 가능)
#   테스트: S2_로 시작 (예: S2_xxxxxxxxxxxxxxxxxxxxxxxx)
#   운영:   R2_로 시작
#
# NICEPAY_SECRET_KEY: 서버에서 빌링키 발급 및 결제 API 호출에 사용 (절대 노출 금지)
#   테스트·운영 모두 나이스페이먼츠 대시보드에서 발급
# =============================================================================
NEXT_PUBLIC_NICEPAY_CLIENT_ID="S2_your_client_id_here"
NICEPAY_SECRET_KEY="your_nicepay_secret_key_here"

# =============================================================================
# 홍보 영상 자동 제작 (Playwright 기반)
#
# PROMO_* 값은 실제 고객 데이터가 아닌 촬영 전용 demo/preview/staging 데이터만 사용합니다.
# PROMO_BLACKLIST는 산출물 manifest/caption/prompt에 포함되면 실패시킬 문자열 목록입니다.
# =============================================================================
PROMO_BASE_URL="http://localhost:3000"
PROMO_EMAIL="promo-demo@example.com"
PROMO_PASSWORD="your-promo-demo-password"
PROMO_WORKSPACE_SLUG="demo-workspace"
PROMO_PUBLIC_TOKEN="your-public-project-token"
PROMO_PROJECT_ID=""
PROMO_OUTPUT_DIR="artifacts/promo"
PROMO_BLACKLIST="real-customer-name,real-company-name"
PROMO_ALLOW_PRODUCTION="false"

# 후속 자동 게시용. MVP는 이 값 없이 Instagram 수동 게시 번들을 생성합니다.
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
